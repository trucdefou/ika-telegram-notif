{
  "manifest_version": 3,
  "name": "Ikariam Telegram Notifier",
  "description": "Sends Telegram notifications for Ikariam game events — attacks, diplomacy, research, and more.",
  "version": "3.1.0",
  "author": "trucdefou",
  "homepage_url": "https://github.com/trucdefou",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.telegram.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.ikariam.gameforge.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
